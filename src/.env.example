SECRET_KEY=your-secret-key-here
DEBUG=True
# Add your computer's LAN IP here too (e.g. 192.168.1.23) so your phone,
# on the same Wi-Fi, can reach the dev server. Find it with `ipconfig`
# (Windows) or `ifconfig`/`ip a` (Mac/Linux).
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.23
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.23:3000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://192.168.1.23:8000

# Postgres connection string. Leave unset for local dev — falls back to
# SQLite automatically. For the free deployment, create a free project at
# https://neon.tech (permanent free tier, no 30-day expiry unlike Render's
# free Postgres) and paste its connection string here. Use the SAME value
# in Render's env vars AND in your local .env when running the worker.
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# Screener
GROQ_API_KEY=gsk_youryour_groq_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
WATCH_FOLDER=/path/to/folder/to/watch/for/screenshots
PUBLIC_BASE_URL=your