SECRET_KEY=your-secret-key-here
DEBUG=True
# Add your computer's LAN IP here too (e.g. 192.168.1.23) so your phone,
# on the same Wi-Fi, can reach the dev server. Find it with `ipconfig`
# (Windows) or `ifconfig`/`ip a` (Mac/Linux).
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.23
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.23:3000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://192.168.1.23:8000

# Screener
GROQ_API_KEY=gsk_your_groq_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
WATCH_FOLDER=/path/to/folder/to/watch/for/screenshots
